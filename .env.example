# API-Football (https://www.api-football.com/) — required for data extraction
APIFOOTBALL_KEY=your_api_football_key_here

# Postgres connection — only needed when running the extractor with --db pg
# and for the Streamlit app's data_access layer.
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DB=metaren
PG_USER=metaren
PG_PASSWORD=change_me
